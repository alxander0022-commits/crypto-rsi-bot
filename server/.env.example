# Copy this file to server/.env and fill it in YOURSELF.
# NEVER commit .env to git (it is in .gitignore).

# demo = api-demo.bybit.com (fake 50k USDT) | live = api.bybit.com (REAL MONEY)
BYBIT_MODE=demo

# Bybit API keys. For DEMO: log in to Bybit -> switch to Demo Trading ->
# avatar -> API -> create key. For LIVE (later): create keys with
# TRADE-ONLY permission, WITHDRAWALS DISABLED, IP-restricted to the VPS.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Password for the control-panel website (pick something strong).
PANEL_PASSWORD=

# Telegram (same bot as the alert system)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
